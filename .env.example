# Copie para .env.local (nunca versionado) e preencha com as chaves do
# projeto Supabase (dev ou prod). Ver CLAUDE.md, seção "Variáveis de ambiente".
#
# Formato novo de chaves do Supabase (Settings > API Keys > Publishable key /
# Secret keys) — sb_publishable_... e sb_secret_..., não as legadas anon/service_role.

# Pública — pode ir ao cliente.
NEXT_PUBLIC_SUPABASE_URL=

# Pública (sb_publishable_...) — respeita RLS, pode ir ao cliente.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Somente servidor (sb_secret_...). Nunca prefixo NEXT_PUBLIC_, nunca importar em componente client.
SUPABASE_SECRET_KEY=
